---
import Layout from '../layouts/Layout.astro';
import MetricsDashboard from '../components/MetricsDashboard.astro';
import { readFileSync, existsSync } from 'fs';
import { join } from 'path';

// Load metrics JSON generated during pre-build
let metricsData;
const metricsPath = join(process.cwd(), 'src', 'data', 'metrics.json');

try {
  if (existsSync(metricsPath)) {
    metricsData = JSON.parse(readFileSync(metricsPath, 'utf8'));
  } else {
    // Fallback for when pre-build hasn't run
    metricsData = {
      since: new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString(),
      until: new Date().toISOString(),
      generatedAt: new Date().toISOString(),
      metrics: {
        velocity: { value: null, unit: 'issues/day' },
        cycleTime: { value: null, unit: 'hours' },
        qualityRate: { value: null, unit: '%', merged: 0, rejected: 0, total: 0 },
        testGrowth: { value: null, unit: 'tests' },
        throughput: { value: null, unit: 'PRs/day' },
        streak: { value: null, unit: 'days' },
      },
      trends: {},
    };
  }
} catch {
  metricsData = null;
}
---

<Layout title="Metrics — Syntax Sorcery" description="Live autonomous performance metrics: velocity, throughput, quality, and more.">
  <main class="container mx-auto px-4 max-w-6xl py-12">

    <!-- Header -->
    <div class="text-center mb-12 scroll-fade">
      <a href="/Syntax-Sorcery/" class="inline-block text-matrix-green/60 hover:text-matrix-green font-mono text-sm mb-6 transition-colors">
        ← Back to Home
      </a>
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4 tracking-tight">
        <span class="bg-gradient-to-r from-matrix-green via-emerald-400 to-matrix-green bg-clip-text text-transparent">
          Performance Metrics
        </span>
      </h1>
      <p class="text-gray-500 max-w-xl mx-auto font-mono text-sm">
        Autonomous development KPIs — updated at each site build.
      </p>
    </div>

    <!-- Dashboard -->
    {metricsData ? (
      <MetricsDashboard data={metricsData} />
    ) : (
      <div class="text-center p-12 glass rounded-xl">
        <p class="text-gray-400 font-mono text-sm">Metrics data unavailable. Run the build to generate.</p>
      </div>
    )}

    <!-- Data Source Info -->
    <div class="scroll-fade glass rounded-xl p-5 mt-12 max-w-5xl mx-auto">
      <h2 class="text-sm font-mono text-matrix-green/80 mb-3">Data Source</h2>
      <div class="flex flex-wrap gap-6 text-xs text-gray-400 font-mono">
        <span class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-matrix-green inline-block"></span>
          GitHub API via <code class="text-matrix-green/60 ml-1">gh</code> CLI
        </span>
        <span class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-cyan-400 inline-block"></span>
          Generated by <code class="text-matrix-green/60 ml-1">metrics-engine.js</code>
        </span>
        <span class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-purple-400 inline-block"></span>
          Static JSON at build time — no runtime deps
        </span>
      </div>
    </div>

    <!-- Footer -->
    <footer class="scroll-fade text-center pt-8 pb-4 border-t border-gray-800/50 mt-16">
      <p class="text-gray-600 text-xs font-mono">
        <span class="text-matrix-green/40">⟨SS⟩</span> Performance Metrics — Syntax Sorcery
      </p>
      <p class="text-gray-700 text-xs mt-1 font-mono">
        Powered by metrics-engine.js • No external dependencies
      </p>
    </footer>

  </main>
</Layout>
